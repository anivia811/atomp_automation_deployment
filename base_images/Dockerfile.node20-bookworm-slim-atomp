# Reconstructed from `docker history node:20-bookworm-slim-atomp` — this tag
# was never on Docker Hub, it only existed as a local image, which broke
# `docker build` for tester40-web on any machine that hadn't built it before.
FROM node:20-bookworm-slim

RUN apt-get update && \
    apt-get install -y gettext-base && \
    apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

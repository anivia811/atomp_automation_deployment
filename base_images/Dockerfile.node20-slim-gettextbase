# Reconstructed from `docker history node:20-slim-gettextbase` — this tag was
# never on Docker Hub, it only existed as a local image, which broke
# `docker build` for studio-web/storage-web on any machine that hadn't built
# it before.
FROM node:20-slim

RUN apt-get update -y && \
    apt-get install -y --no-install-recommends gettext-base python3 build-essential && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

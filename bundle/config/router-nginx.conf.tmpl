worker_processes 2;
events { worker_connections 1024; }

http {
  # ── App services (atomp_automation_network) ────────────────────────────────
  upstream tester40_client    { server tester40-client:3000; }
  upstream tester40_api       { server tester40-web:3000; }
  upstream tester40_websocket { server tester40-web:3030; }
  upstream tester40_tasker    { server tasker-web:3000; }
  upstream studio_client      { server studio-client:3000; }
  upstream studio_api         { server studio-web:3000; }
  upstream studio_websocket   { server studio-web:3030; }
  upstream storage_api        { server storage-web:3000; }

  # ── Device Farm services (deploy_master_default) ───────────────────────────
  upstream df_app              { server app:3000 max_fails=0; }
  upstream df_websocket        { server websocket:3000 max_fails=0; }
  upstream df_api              { server api:3000 max_fails=0; }
  upstream df_storage          { server storage-temp:3000 max_fails=0; }
  upstream df_storage_image    { server storage-plugin-image:3000 max_fails=0; }
  upstream df_storage_apk      { server storage-plugin-apk:3000 max_fails=0; }
  upstream df_storage_ipa      { server storage-plugin-ipa:3000 max_fails=0; }
  upstream df_storage_permanent{ server storage-permanent:3000 max_fails=0; }
  upstream df_stream_gate      { server stream-gate:3000 max_fails=0; }
  upstream df_stream_gate_audio{ server stream-gate-audio:3000 max_fails=0; }

  # ── Atomid (atomid_deployment_atomid) ─────────────────────────────────────
  upstream atomid { server atomid:8081; }

  map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
  }

  server_tokens off;
  client_max_body_size 5000M;
  access_log /dev/stdout;
  error_log  /dev/stderr;

  server {
    listen 80;

    location = / { return 302 /atomid/; }

    # ── Tester40 ─────────────────────────────────────────────────────────────
    location /tester40/socket.io/ {
      rewrite ^/tester40/(.*) /$1 break;
      proxy_pass http://tester40_websocket;
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection "Upgrade";
    }
    location /tester40/api {
      proxy_pass http://tester40_api;
      proxy_read_timeout 300;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Real-IP $http_x_real_ip;
    }
    location /tester40/uploads {
      rewrite ^/tester40/(.*) /$1 break;
      proxy_pass http://tester40_api;
    }
    location /tester40/lib {
      rewrite ^/tester40/(.*) /$1 break;
      proxy_pass http://tester40_api;
    }
    location /tester40 {
      rewrite ^/tester40(.*) /$1 break;
      proxy_pass http://tester40_client;
      proxy_redirect off;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header HOST $http_host;
    }

    # ── Tasker ───────────────────────────────────────────────────────────────
    location /tasker/api {
      proxy_pass http://tester40_tasker;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # ── Studio ───────────────────────────────────────────────────────────────
    location /studio/socket {
      rewrite ^/studio(.*) /$1 break;
      proxy_pass http://studio_websocket;
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection "Upgrade";
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
    location /studio/api {
      proxy_pass http://studio_api;
      proxy_read_timeout 300;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
    location /studio {
      rewrite ^/studio(.*) /$1 break;
      proxy_pass http://studio_client;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header HOST $http_host;
    }

    # ── Storage ──────────────────────────────────────────────────────────────
    location /storage {
      proxy_pass http://storage_api;
      proxy_read_timeout 24h;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # ── Atomid ───────────────────────────────────────────────────────────────
    location = /atomid { return 301 /atomid/; }
    location /atomid/ {
      proxy_pass http://atomid/;
      proxy_set_header Accept-Encoding '';
      sub_filter_types text/html text/javascript application/javascript;
      sub_filter_once off;
      sub_filter '<base href="/">' '<base href="/atomid/">';
      sub_filter 'https://tester40.atomp.io/' 'http://__SERVER_IP__/tester40/';
      sub_filter 'https://devicefarm.atomp.io/' 'http://__SERVER_IP__:8180/devicefarm/';
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header Host $http_host;
    }
    location /api/ {
      proxy_pass http://atomid/api/;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
    location /assets/ {
      proxy_pass http://atomid/assets/;
    }

    # ── Device Farm ──────────────────────────────────────────────────────────
    location = /devicefarm { return 301 /devicefarm/; }
    location /devicefarm/socket.io/ {
      proxy_pass http://df_websocket/socket.io/;
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection "Upgrade";
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
    location /devicefarm/api/ {
      proxy_pass http://df_api/api/;
      proxy_read_timeout 3600s;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
    location /devicefarm/s/image/    { proxy_pass http://df_storage_image/s/image/; add_header Access-Control-Allow-Origin *; }
    location /devicefarm/s/apk/      { proxy_pass http://df_storage_apk/s/apk/; }
    location /devicefarm/s/ipa/      { proxy_pass http://df_storage_ipa/s/ipa/; }
    location /devicefarm/s/permanent/{ proxy_pass http://df_storage_permanent/s/permanent/; }
    location /devicefarm/s/          { proxy_pass http://df_storage/s/; }
    location /devicefarm/c/ {
      proxy_pass http://df_stream_gate/;
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection $connection_upgrade;
    }
    location /devicefarm/c-audio/ {
      proxy_pass http://df_stream_gate_audio/;
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection $connection_upgrade;
    }
    location /devicefarm/ {
      proxy_pass http://df_app/;
      proxy_redirect / /devicefarm/;
      proxy_cookie_flags token "";
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
  }
}
